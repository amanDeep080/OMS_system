# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database (Neon PostgreSQL in production, local Postgres in dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spreetail_dev
DB_SSL=false

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Nodemailer (SMTP) - used for forgot-password / verification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Spreetail HR <no-reply@spreetail.com>"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
